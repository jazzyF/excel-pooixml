package com.fola;

import org.apache.poi.ss.usermodel.*;
import org.apache.poi.ss.util.CellRangeAddress;

public class ExcelDumper {
    public static void main(String[] args) throws Exception {
        Workbook wb = WorkbookFactory.create(new File(args[0]));

        System.out.println("Sheets: " + wb.getNumberOfSheets());

        for (int s = 0; s < wb.getNumberOfSheets(); s++) {
            Sheet sheet = wb.getSheetAt(s);
            System.out.println("\n=== Sheet: " + sheet.getSheetName() + " ===");

            // Dump merged regions
            System.out.println("Merged Regions: " + sheet.getNumMergedRegions());
            for (int i = 0; i < sheet.getNumMergedRegions(); i++) {
                CellRangeAddress r = sheet.getMergedRegion(i);
                System.out.println("  " + r.formatAsString()); // e.g. A1:D3
            }

            // Dump cell values
            for (Row row : sheet) {
                for (Cell cell : row) {
                    System.out.printf("  [%s] Type=%-10s Value=%s%n",
                        cell.getAddress(),
                        cell.getCellType(),
                        getCellValue(cell)
                    );
                }
            }
        }
        wb.close();
    }

    static String getCellValue(Cell cell) {
        switch (cell.getCellType()) {
            case STRING:  return cell.getStringCellValue();
            case NUMERIC: return String.valueOf(cell.getNumericCellValue());
            case BOOLEAN: return String.valueOf(cell.getBooleanCellValue());
            case FORMULA: return cell.getCellFormula();
            default:      return "(empty)";
        }
    }
}
